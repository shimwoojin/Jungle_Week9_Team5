body {
	width: 100%;
	height: 100%;
	margin: 0px;
	background-color: #15171cf2;
	color: #ffffff;
	font-family: Maplestory;
	font-weight: bold;
	text-align: center;
}

#game-over-frame {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	background-color: #15171cf2;
}

#game-over-top-line {
	position: absolute;
	left: 8%;
	top: 8%;
	width: 84%;
	height: 4dp;
	background-color: #f0c85a;
}

#game-over-bottom-line {
	position: absolute;
	left: 8%;
	top: 92%;
	width: 84%;
	height: 4dp;
	background-color: #f0c85a;
}

#game-over-kicker {
	position: absolute;
	left: 0%;
	top: 16%;
	width: 100%;
	height: 32dp;
	color: #f0c85a;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 20dp;
	line-height: 32dp;
	text-align: center;
}

#game-over-title {
	position: absolute;
	left: 0%;
	top: 25%;
	width: 100%;
	height: 96dp;
	color: #ffffff;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 64dp;
	line-height: 96dp;
	text-align: center;
}

#game-over-subtitle {
	position: absolute;
	left: 0%;
	top: 42%;
	width: 100%;
	height: 30dp;
	color: #aeb6c8;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 18dp;
	line-height: 30dp;
	text-align: center;
}

#final-score-value {
	position: absolute;
	left: 0%;
	top: 47%;
	width: 100%;
	height: 64dp;
	color: #f0c85a;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 48dp;
	line-height: 64dp;
	text-align: center;
}

#restart-button {
	position: absolute;
	left: 50%;
	top: 62%;
	width: 300dp;
	height: 58dp;
	margin-left: -150dp;
	border-width: 3dp;
	border-color: #f0c85a;
	background-color: #252a34;
	color: #ffffff;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 24dp;
	line-height: 52dp;
	text-align: center;
}

#game-over-exit-button {
	position: absolute;
	left: 50%;
	top: 73%;
	width: 300dp;
	height: 58dp;
	margin-left: -150dp;
	border-width: 3dp;
	border-color: #f0c85a;
	background-color: #252a34;
	color: #ffffff;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 24dp;
	line-height: 52dp;
	text-align: center;
}

#game-over-footer {
	position: absolute;
	left: 0%;
	top: 86%;
	width: 100%;
	height: 28dp;
	color: #747d91;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 16dp;
	line-height: 28dp;
	text-align: center;
}
