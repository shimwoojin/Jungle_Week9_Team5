body {
	width: 100%;
	height: 100%;
	margin: 0px;
	background-color: transparent;
	color: #ffffff;
	font-family: Maplestory;
	font-weight: bold;
	text-align: center;
}

@keyframes intro-title-pop-in {
	from {
		opacity: 0;
		transform: scale(0.82);
	}

	60% {
		opacity: 1;
		transform: scale(1.08);
	}

	to {
		opacity: 1;
		transform: scale(1);
	}
}

@keyframes intro-title-pulse {
	from {
		transform: scale(1);
	}

	50% {
		transform: scale(1.05);
	}

	to {
		transform: scale(1);
	}
}

#intro-frame {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	background-color: #15171c;
}

#intro-background {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
}

#intro-dim {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	background-color: #000000aa;
}

#intro-top-line {
	position: absolute;
	left: 8%;
	top: 8%;
	width: 84%;
	height: 4dp;
	background-color: #f0c85a;
}

#intro-bottom-line {
	position: absolute;
	left: 8%;
	top: 92%;
	width: 84%;
	height: 4dp;
	background-color: #f0c85a;
}

#intro-kicker {
	position: absolute;
	left: 0%;
	top: 14%;
	width: 100%;
	height: 32dp;
	color: #f0c85a;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 20dp;
	line-height: 32dp;
	text-align: center;
}

#intro-title-pop {
	position: absolute;
	left: 50%;
	top: 16%;
	width: 480dp;
	height: 480dp;
	margin-top: 50dp;
	margin-left: -240dp;
	animation: 0.58s cubic-out intro-title-pop-in;
}

#intro-title {
	width: 480dp;
	height: 480dp;
	animation: 1.6s sine-in-out infinite intro-title-pulse;
}

#intro-subtitle {
	position: absolute;
	left: 0%;
	top: 58%;
	width: 100%;
	height: 32dp;
	color: #aeb6c8;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 18dp;
	line-height: 32dp;
	text-align: center;
}

#start-button {
	position: absolute;
	left: 50%;
	top: 65%;
	width: 300dp;
	height: 58dp;
	margin-left: -150dp;
	border-width: 3dp;
	border-color: #f0c85a;
	background-color: #252a34;
	color: #ffffff;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 24dp;
	line-height: 52dp;
	text-align: center;
}

#start-button,
#scoreboard-button,
#exit-button {
	transition: background-color border-color color 0.16s sine-out;
}

#start-button:hover,
#scoreboard-button:hover,
#exit-button:hover {
	border-color: #ffe58a;
	background-color: #f0c85a;
	color: #15171c;
}

#scoreboard-button {
	position: absolute;
	left: 50%;
	top: 74%;
	width: 300dp;
	height: 58dp;
	margin-left: -150dp;
	border-width: 3dp;
	border-color: #f0c85a;
	background-color: #252a34;
	color: #ffffff;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 24dp;
	line-height: 52dp;
	text-align: center;
}

#exit-button {
	position: absolute;
	left: 50%;
	top: 83%;
	width: 300dp;
	height: 58dp;
	margin-left: -150dp;
	border-width: 3dp;
	border-color: #f0c85a;
	background-color: #252a34;
	color: #ffffff;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 24dp;
	line-height: 52dp;
	text-align: center;
}

#intro-footer {
	position: absolute;
	left: 0%;
	top: 90%;
	width: 100%;
	height: 28dp;
	color: #747d91;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 16dp;
	line-height: 28dp;
	text-align: center;
}
