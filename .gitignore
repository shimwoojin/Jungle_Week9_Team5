# ============================================================
# Per-config build output (Visual Studio default folders)
# Source/ 와 ThirdParty/ 하위는 동명 디렉터리(Source/Editor/Debug 류)가 있을 수 있으니 예외.
# ============================================================
[Dd]ebug/
!**/Source/**/[Dd]ebug/
!**/ThirdParty/**/[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
!**/Source/**/[Rr]elease/
!**/ThirdParty/**/[Rr]elease/
[Rr]eleases/
ObjView*Debug/
**/Build/

# Per-platform output
[Dd]ebug/x64/
[Rr]elease/x64/
bin/x64/
obj/x64/
[Dd]ebug/x86/
[Rr]elease/x86/
bin/x86/
obj/x86/
[Ww][Ii][Nn]32/

# Bin/ 안의 산출물 (Bin 폴더 자체는 유지)
**/[Bb]in/*

# ============================================================
# 패키징 산출물 (root 의 *Build/ 폴더, 그리고 Game/)
# Source/Game/ 같은 추적 대상과 겹치지 않도록 root-only(/) 로 잡는다.
# ============================================================
/GameBuild/
/ReleaseBuild/
/Game/

# ============================================================
# Engine 런타임 산출물
# ============================================================
Saves/

# ============================================================
# 메시 캐시 (.bin, .mbin) — 런타임 재생성됨
# ============================================================
*.bin
*.mbin

# ============================================================
# NuGet (PhysX 등) — packages/ 캐시는 복원되니 추적 안 함
# ============================================================
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

